# 이룸(ELUM) 클라이언트 환경변수 예시
#
# 이 파일은 "어떤 키가 필요한지" 알려주는 문서다. 실제 값은 .env에 넣는다.
# .env는 커밋하지 않는다 (.gitignore 등록됨).
#
# 사용법:
#   1. cp .env.example .env
#   2. 아래 값을 환경에 맞게 채운다
#   3. CI/배포용 값은 GitHub Secret CLIENT_ENV_FILE에 .env 전체 내용을 등록한다
#
# 새 키를 추가할 땐 반드시 (1) 이 파일 (2) AppConfig 를 함께 수정한다.

# --- 서버 ---
# 운영: https://api.elum.chuseok22.com
# 로컬: http://localhost:8080
# Android 에뮬레이터에서 로컬 서버를 볼 땐 http://10.0.2.2:8080
ELUM_API_BASE_URL=https://api.elum.chuseok22.com

# 요청 타임아웃 (밀리초). 로컬 LLM 카드 생성은 오래 걸릴 수 있어 넉넉히 둔다.
ELUM_API_CONNECT_TIMEOUT_MS=10000
ELUM_API_RECEIVE_TIMEOUT_MS=60000

# --- 데모 연출 ---
# AI DLP 처리 최소 노출 시간 (밀리초).
# 응답이 빨라도 보안 처리를 체감시키기 위해 유지한다 (docs/07-mvp-scope.md 데모 안전 수칙).
ELUM_DLP_MIN_DELAY_MS=1500

# --- 개발 ---
# 네트워크 로깅. 운영에서는 false.
# ⚠️ true여도 보호자 입력 원문은 절대 로그에 남기지 않는다 (docs 원칙 5번).
ELUM_ENABLE_NETWORK_LOG=true

# 서버 없이 mock 데이터로 동작시킬지 여부.
# ⚠️ true면 최근 일과 목록이 항상 비어 있고 일과 생성도 로컬로만 돈다.
#    서버 API가 붙었으므로 실제 동작을 보려면 false로 둔다. (이슈 #19)
ELUM_USE_MOCK=false

# 개발자 도구 오버레이(플로팅 버튼)를 띄울지.
# 회원삭제·로그 확인·화면 이동을 앱 안에서 할 수 있다.
# ⚠️ 심사자·테스터가 릴리스 빌드로 확인해야 하므로 kDebugMode를 걸지 않았다.
#    정식 출시 전 반드시 false로 바꾼다. (이슈 #13)
ELUM_SHOW_DEV_TOOLS=true
